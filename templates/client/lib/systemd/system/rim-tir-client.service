[Unit]
Description=RiM-TiR Client
After=network-online.target mosquitto.service
Wants=network-online.target

[Service]
User=rimtir
Group=rimtir
WorkingDirectory=/var/lib/rim-tir/client
ExecStart=/usr/bin/rim-tir-backend -config /etc/rim-tir/client.yaml
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
