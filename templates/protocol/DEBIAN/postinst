#!/bin/sh
set -e

if ! id rimtir >/dev/null 2>&1; then
    adduser --system --group --home /var/lib/rim-tir rimtir >/dev/null
fi

install -d -o rimtir -g rimtir /var/lib/rim-tir/protocol
install -d -o rimtir -g rimtir /var/log/rim-tir/protocol

if command -v systemctl >/dev/null 2>&1; then
    systemctl daemon-reload
    systemctl enable rim-tir-protocol.service >/dev/null || true
    systemctl restart rim-tir-protocol.service || true
fi

exit 0
